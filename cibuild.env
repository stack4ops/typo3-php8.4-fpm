CIBUILD_LOG_LEVEL=3
CIBUILD_TARGET_IMAGE_PATH=stack4ops/typo3-php
CIBUILD_CHECK_ENABLED=1
CIBUILD_BUILD_NATIVE=1
CIBUILD_BUILD_FORCE=1
CIBUILD_BUILD_SBOM=1
CIBUILD_BUILD_PROVENANCE=1
CIBUILD_RELEASE_IMAGE_TAGS=__MINORTAG__
CIBUILD_RELEASE_MINOR_TAG_REGEX='^8\.4\.\d+-fpm\-trixie$'
CIBUILD_RELEASE_SIGNATURE=1
